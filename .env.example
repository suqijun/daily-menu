# ========== Supabase（前端可读，复制 Project URL 和 anon key）==========
# 获取位置：Supabase 项目 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://你的项目ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=你的anon_key

# ========== AI 服务（换密钥 / 换平台时只改这里）==========
# 注意：这三项只在服务端使用，不要加 NEXT_PUBLIC_ 前缀
AI_API_KEY=sk-请粘贴你的密钥
AI_BASE_URL=https://你的服务商提供的地址/v1
AI_MODEL=你的模型名

# ========== 可选微调（可不动）==========
AI_TIMEOUT_MS=45000
AI_TEMPERATURE=0.7
